# =============================================================================
# VaaniSeva Environment Variables Template
# Copy to .env and fill in your values: cp env.template .env
# =============================================================================

# --- Databricks Workspace ---
# Your Databricks workspace URL (e.g., https://adb-xxxx.yy.azuredatabricks.net)
DATABRICKS_HOST=
# Databricks CLI profile name (run: databricks auth login --host <url> --profile <name>)
DATABRICKS_PROFILE=DEFAULT

# --- Lakebase (Autoscaling PostgreSQL) ---
# Created by setup.sh — fill in after running it
LAKEBASE_PROJECT=vaaniseva
LAKEBASE_BRANCH=production
LAKEBASE_ENDPOINT=primary
LAKEBASE_HOST=
LAKEBASE_DB_NAME=vaaniseva

# --- Sarvam AI (https://dashboard.sarvam.ai) ---
# Sign up at https://dashboard.sarvam.ai — free tier available
SARVAM_API_KEY=
# Model endpoint name on Databricks (optional — for self-hosted Sarvam-30B)
SARVAM_ENDPOINT_NAME=sarvam-30b-serving

# --- Twilio Voice (https://console.twilio.com) ---
# From Twilio Console > Account > Keys & Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio phone number (format: +1XXXXXXXXXX)
TWILIO_PHONE_NUMBER=
# WhatsApp sandbox number (default Twilio sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Twilio Functions (created manually — see INSTALL.md Step 4) ---
# URL of your deployed Twilio Function for Sarvam TTS audio
# Example: https://your-service-xxxx.twil.io/audio
SARVAM_TTS_URL=

# --- Twilio Function Environment Variables ---
# These are set IN Twilio Console (not locally). Listed here for reference.
# T1, T2, T3, T4 = Databricks OAuth token split into 4 parts (max 255 chars each)
# SARVAM_KEY = Same as SARVAM_API_KEY above
# APP_HOST = Your Databricks App hostname (without https://)

# --- Optional ---
# Vector Search endpoint (if using RAG over policy docs)
VS_ENDPOINT_NAME=
VS_INDEX_NAME=
# Genie Space ID (if using NL-to-SQL showcase)
GENIE_SPACE_ID=
# Log level
LOG_LEVEL=INFO
