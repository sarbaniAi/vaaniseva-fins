flowchart TB

    %% ══════════════════════════════════════════════════════════════
    %%  BANNER — top row
    %% ══════════════════════════════════════════════════════════════
    BANNER["🟠  100% India-Hosted AI — Full Data Sovereignty  ⚪  🟢\nAPJ Buildathon 2026  ·  BFSI Collections Voice Agent  ·  22 Indian Languages"]:::banner

    %% ══════════════════════════════════════════════════════════════
    %%  MAIN ARCHITECTURE — one big subgraph below the banner
    %% ══════════════════════════════════════════════════════════════
    subgraph MAIN[" "]
        direction LR

        %% ── CUSTOMER ──
        subgraph CUST["  Customer Devices  "]
            direction TB
            CP["📞 Customer Phone\nPSTN Voice Calls"]:::custNode
            CW["💬 Customer\nWhatsApp"]:::custNode
        end

        %% ── TWILIO ──
        subgraph TWILIO["  Twilio Communication Layer  "]
            direction TB
            TV["🔊 Programmable Voice\nWebSocket Streaming"]:::twilioNode
            TF["⚡ Twilio Function\n34-line Serverless Relay"]:::twilioNode
            TW["💬 WhatsApp Sandbox\nWebhook"]:::twilioNode
        end

        %% ── DATABRICKS ──
        subgraph DB["  ☁  Databricks Platform  "]
            direction TB

            subgraph APP["  Databricks App  (FastAPI)  "]
                direction LR
                T1["🖥 Customer\nSimulator"]:::appTab
                T2["👁 Agent\nLive View"]:::appTab
                T3["✅ Quality\nAuditor"]:::appTab
                T4["📲 WhatsApp\nFlow Engine"]:::appTab
            end

            subgraph FSM["  Call Flow State Machine  "]
                direction LR
                S1(["🙏 Greeting"]):::state --> S2(["🔍 Verify"]):::state --> S3(["💬 Purpose"]):::state --> S4(["🤝 Negotiate"]):::state --> S5(["✅ Resolve"]):::state --> S6(["👋 Close"]):::state
                S4 -.->|escalate| S7{{"⚠ Escalate"}}:::esc
            end

            subgraph LB["  Databricks Lakebase  (Autoscaling PostgreSQL)  "]
                direction LR
                TB1[("customer_profiles\n50 rows")]:::dbTable
                TB2[("loan_accounts\n80 rows")]:::dbTable
                TB3[("payment_history\n613 rows")]:::dbTable
                TB4[("knowledge_base\n40 rows")]:::dbTable
                TB5[("call_logs\nquality_scores")]:::dbTable
            end
        end

        %% ── SARVAM AI ──
        subgraph SAI["  🇮🇳  Sarvam AI — India Hosted  "]
            direction TB
            STT["🎙 STT — Saaras v3\n22 Indian Languages"]:::sarvamNode
            LLM["🧠 LLM — Sarvam-M / 30B\nReasoning Engine"]:::sarvamNode
            TTS["🔈 TTS — Bulbul v2\n11 Voices"]:::sarvamNode
            STT -->|"② Transcript"| LLM
            LLM -->|"③ Response"| TTS
        end

        %% ── CONNECTIONS INSIDE MAIN ──

        %% Voice path
        CP <-->|"PSTN"| TV
        TV <-->|"WebSocket\nAudio"| APP

        %% WhatsApp path
        CW <-->|"WhatsApp API"| TW
        TW -->|"Webhook"| TF
        TF <-->|"HTTP Relay"| APP

        %% App ↔ Lakebase
        APP <-->|"SQL Queries\ncustomer · loans · payments"| LB

        %% App → FSM
        APP -.-|"drives"| FSM

        %% App ↔ Sarvam AI (voice pipeline — numbered steps)
        APP -->|"① Audio Out  ④ Audio In"| STT
    end

    %% Banner → Main (top-down flow)
    BANNER --> MAIN

